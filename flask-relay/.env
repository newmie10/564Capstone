# Source IPs allowed to hit each relay endpoint
PEER_A_IP=172.17.0.1
PEER_B_IP=172.17.0.1

# Where each relay forwards to
PEER_A_FORWARD=http://172.17.0.1:9000
PEER_B_FORWARD=http://172.17.0.1:8000

FORWARD_TIMEOUT=30

# Set true ONLY if behind a trusted reverse proxy (nginx/Caddy/etc) so X-Forwarded-For is honored
TRUST_PROXY=false
